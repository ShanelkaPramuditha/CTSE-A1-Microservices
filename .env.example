IMAGE_REGISTRY=ghcr.io/your-github-username
IMAGE_TAG=latest
MONGO_PORT=27017

PORT_API_GATEWAY=3000

USER_SERVICE_HOST=user-service
USER_SERVICE_PORT=4001

PRODUCT_SERVICE_HOST=product-service
PRODUCT_SERVICE_PORT=4002

ORDER_SERVICE_HOST=order-service
ORDER_SERVICE_PORT=4003

PAYMENT_SERVICE_HOST=payment-service
PAYMENT_SERVICE_PORT=4004

CART_SERVICE_HOST=cart-service
CART_SERVICE_PORT=4005

MONGO_URI_USER=mongodb://mongo:27017/user-db
MONGO_URI_PRODUCT=mongodb://mongo:27017/product-db
MONGO_URI_ORDER=mongodb://mongo:27017/order-db
MONGO_URI_PAYMENT=mongodb://mongo:27017/payment-db
MONGO_URI_CART=mongodb://mongo:27017/cart-db

JWT_SECRET=change-me
JWT_EXPIRATION=3600s
