{
  "name": "ecommerce-microservices",
  "version": "1.0.0",
  "description": "E-Commerce Microservices Backend with NestJS",
  "private": true,
  "scripts": {
    "build:gateway": "nest build api-gateway",
    "build:user": "nest build user-service",
    "build:order": "nest build order-service",
    "build:product": "nest build product-service",
    "build:payment": "nest build payment-service",
    "build:all": "pnpm run build:gateway && pnpm run build:user && pnpm run build:order && pnpm run build:product && pnpm run build:payment",
    "start:gateway": "nest start api-gateway",
    "start:user": "nest start user-service",
    "start:order": "nest start order-service",
    "start:product": "nest start product-service",
    "start:payment": "nest start payment-service",
    "start:dev:gateway": "nest start api-gateway --watch",
    "start:dev:user": "nest start user-service --watch",
    "start:dev:order": "nest start order-service --watch",
    "start:dev:product": "nest start product-service --watch",
    "start:dev:payment": "nest start payment-service --watch",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "format": "prettier --write \"{apps,libs}/**/*.ts\"",
    "test": "jest",
    "test:cov": "jest --coverage",
    "kill:all": "lsof -ti:3000,4001,4005 | xargs -r kill -9"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.17",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "mongoose": "^9.3.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
